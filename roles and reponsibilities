if (pid == 0)  // Child process
{
    // Redirections happen here
    execve(cmd_path, args, environ);
    perror("execve");
    exit(127);
}
else if (pid > 0)  // Parent process
{
    waitpid(pid, &status, 0);
    // Extract exit code
    int exit_code = WEXITSTATUS(status);
}
else  // pid == -1, error
{
    perror("fork");
}
```

